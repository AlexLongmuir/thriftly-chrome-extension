{
  "name": "scouted-by-thriftly-chrome-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "dev": "vite --host 127.0.0.1",
    "extension:activate": "npm run build && mkdir -p /Users/alex/Documents/scouted-extension-active && rsync -a --delete dist/ /Users/alex/Documents/scouted-extension-active/",
    "chat:new": "node scripts/worktree.mjs new",
    "chat:list": "node scripts/worktree.mjs list",
    "chat:done": "node scripts/worktree.mjs done",
    "chat:cleanup": "node scripts/worktree.mjs cleanup",
    "worktree:new": "node scripts/worktree.mjs new",
    "worktree:list": "node scripts/worktree.mjs list",
    "worktree:done": "node scripts/worktree.mjs done",
    "worktree:cleanup": "node scripts/worktree.mjs cleanup",
    "worktree:guard": "node scripts/worktree.mjs guard",
    "hooks:install": "node scripts/worktree.mjs install-hooks",
    "audit:url-set": "vite-node scripts/audit-url-set.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.320",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^26.0.0",
    "vitest": "^3.0.0"
  }
}
