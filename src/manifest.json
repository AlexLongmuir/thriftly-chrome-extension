{
  "manifest_version": 3,
  "name": "Scouted by Thriftly",
  "description": "Scouted by Thriftly helps you judge clothing quality, value, durability, and style signals directly on product pages.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "permissions": ["activeTab", "declarativeNetRequestWithHostAccess", "scripting", "sidePanel", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Scouted by Thriftly",
    "default_icon": {
      "16": "assets/icon.svg",
      "32": "assets/icon.svg",
      "48": "assets/icon.svg",
      "128": "assets/icon.svg"
    }
  },
  "icons": {
    "16": "assets/icon.svg",
    "32": "assets/icon.svg",
    "48": "assets/icon.svg",
    "128": "assets/icon.svg"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "panel.html"
  }
}
